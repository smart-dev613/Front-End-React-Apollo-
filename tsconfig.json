{
  "compilerOptions": {
      "outDir": "./dist/",
      "sourceMap": true,
      "noImplicitAny": false,
      "noImplicitReturns": false,
      "module": "commonjs",
      "target": "es6",
      "jsx": "react",
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "removeComments": true,
      "skipLibCheck": true,
      "moduleResolution": "node",
      "lib": [
        "dom",
        "dom.iterable",
        "esnext"
      ],
      "allowJs": true
      
  },
  "awesomeTypescriptLoaderOptions": {
    "useBabel": true,
    "useCache": true,
    "forceIsolatedModules": true,
    "babelCore": "@babel/core"
  },
  "include": [
    "./src/",
    "custom.d.ts"
  ],
  "typeRoots": [
    "./types",
    "./node_modules/@types"
  ]
}